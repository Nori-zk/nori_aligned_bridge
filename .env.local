#http://51.89.227.117:8080/graphql
#https://plain-1-graphql.mina-mesa-network.gcp.o1test.net/graphql
MINA_NETWORK=devnet

# Mina archive node RPC
MINA_ARCHIVE_RPC_URL=https://devnet-archive-node-api.gcp.o1test.net
#https://archive-node.devnet.nori.it.com
#https://archive-node.devnet.nori.it.com
#http://51.89.227.117:8282
#http://mesa-archive-node-api.gcp.o1test.net

# Nori FungibleToken contract address on Mina (token base address)
NORI_MINA_TOKEN_BASE_ADDRESS=B62qr6NqtKgEjWLUjUc8NpbUyUG3dbshVfayKtRChHWCzZyJAkuy26P
# Nori token bridge token ID on Mina
NORI_MINA_TOKEN_BRIDGE_TOKEN_ID=4602798912481687955044945359227003599380738081646655707714184285015901808734

# Ethereum ==============================================================

# For testing we have a bridge operator keypair -- anvil account 2 (pre-funded 10000 ETH).
# Accounts 0-1 reserved by aligned operator/deployer scripts
# (fund_operator_devnet.sh, mint_mock_token.sh).
# Anvil HD mnemonic: "test test test test test test test test test test test junk"
# Derivation: m/44'/60'/0'/0/2

# JSON-RPC endpoint. Points to the anvil container exposed on host port 8545.
ETH_RPC_URL=http://localhost:8545

# Private key. Signs Ethereum transactions (e.g. ETH unlock) and aligned batcher
# proof submissions.
ETH_PRIVATE_KEY=

# Ethereum contract addresses -- REPLACE with real values before use
NORI_ETH_MINA_STATE_SETTLEMENT_ADDRESS=
NORI_ETH_TOKEN_BRIDGE_ADDRESS=

# Aligned layer ===============================================================
# (source: yetanotherco/aligned_layer staging branch)

# Which aligned network to connect to. Determines the batcher websocket URL and
# chain ID. "devnet" targets the local anvil chain (chain ID 31337).
# Batcher WS URLs per network (hardcoded in aligned SDK):
#   devnet  -> ws://localhost:8080  (docker-compose-aligned.local.yml exposes 8080:8080)
#   mainnet -> wss://mainnet.batcher.alignedlayer.com
ALIGNED_NETWORK=devnet

# The AlignedLayer service manager smart contract. On-chain entry point that the
# aligned SDK calls to check whether a proof batch has been verified.
# Value: "alignedLayerServiceManager" field from
# contracts/script/output/devnet/alignedlayer_deployment_output.json.
# Baked into the anvil pre-deployed state loaded by docker-compose-aligned.local.yml.
ALIGNED_ETH_SERVICE_MANAGER_ADDRESS=0x851356ae760d987E095750cCeb3bC6014560891C

# Public address of ETH_PRIVATE_KEY. Embedded in aligned SDK VerificationData as
# on-chain attribution for who submitted the proof. Must be the same keypair.
ALIGNED_PROOF_GENERATOR_ADDRESS=0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC

# Logging default level
NORI_LOG=info

