# Comma-separated mongodb uri replica set all three listed so the client survives any single going down
# Use with local.yml
#MONGODB_URI=mongodb://sa:Password123@localhost:27017/?replicaSet=rs0&authSource=admin (for local.yml)
MONGODB_URI=mongodb://sa:Password123@localhost:27017,localhost:27018,localhost:27019/?replicaSet=rs0&authSource=admin
#MONGODB_URI=mongodb://sa:password@127.0.10.1:27017,127.0.10.2:27017,127.0.10.3:27017/?replicaSet=rs0&authSource=admin (for prod.yml)
MONGODB_DATABASE=nori_aligned_bridge

# Mina ==================================================================

# Mina daemon RPC
MINA_RPC_NETWORK_URL=https://devnet-plain-1.gcp.o1test.net/graphql
#https://mina-node.devnet.nori.it.com/graphql
#https://api.minascan.io/node/devnet/v1/graphql
